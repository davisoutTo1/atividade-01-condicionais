algoritmo "algoritmo10"

var
   dividendo, divisor, quociente, resto: inteiro

inicio

   leia(dividendo)
   leia(divisor)

   quociente <- dividendo div divisor
   resto <- dividendo mod divisor

   escreval("Dividendo: ", dividendo)
   escreval("Divisor: ", divisor)
   escreval("Quociente: ", quociente)
   escreval("Resto: ", resto)

fimalgoritmo
